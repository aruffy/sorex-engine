{
    "version": 2,
    "configurePresets": [
        {
            "name": "win_x64_debug_2",
            "displayName": "Windows x64 (Debug)",
            "description": "Windows x64 build with Ninja generator",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "SOREX_STATIC_LIBRARY": "ON",
                "TRACE": "ON"
            }
        },
        {
            "name": "win_x64_unit_tests",
            "displayName": "Windows x64 (Unit Tests)",
            "description": "Engine unit tests for Visual Studio 17 2022",
            "generator": "Visual Studio 17 2022",
            "toolset": "host=x64",
            "architecture": "x64",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe",
                "SOREX_STATIC_LIBRARY": "ON",
                "SRXENG_DISABLE_CHECK": "ON",
                "SRXENG_ADDRESS_SANITIZER": "ON",
                "SOREX_BUILD_SANDBOX": "OFF",
                "SOREX_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "unix_debug",
            "hidden": true,
            "displayName": "Unix Base (Debug)",
            "description": "Debug build preset for Unix based operating systems",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "/usr/bin/clang",
                "CMAKE_CXX_COMPILER": "/usr/bin/clang++",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "SRXENG_ADDRESS_SANITIZER": "ON",
                "TRACE": "ON"
            }
        },
        {
            "name": "linux_debug",
            "displayName": "Linux (Debug)",
            "description": "Debug Linux build",
            "inherits": "unix_debug"
        },
        {
            "name": "macos_debug",
            "displayName": "MacOS (Debug)",
            "description": "Debug MacOS build",
            "inherits": "unix_debug"
        },
        {
            "name": "unit_tests",
            "displayName": "Sorex Unit Tests",
            "description": "Engine unit tests",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "SRXENG_ADDRESS_SANITIZER": "ON",
                "SRXENG_DISABLE_CHECK": "ON",
                "SOREX_BUILD_SANDBOX": "OFF",
                "SOREX_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "win_x64_debug",
            "displayName": "Configure preset using toolchain file",
            "description": "Sets Ninja generator, build and install directory",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "win_x64_unit_tests_build",
            "displayName": "Build Win x64 (Unit Tests)",
            "description": "Build config for unit tests on Windows platform",
            "configurePreset": "win_x64_unit_tests",
            "configuration": "Debug"
        }
    ],
    "testPresets": [
        {
            "name": "unit_tests_run",
            "displayName": "Run Unit Tests (Linux)",
            "description": "Run the engine unit tests",
            "configurePreset": "unit_tests",
            "execution": {
                "steps": [
                    {
                        "command": "ctest",
                        "arguments": [
                            "--output-on-failure",
                            "--test-dir",
                            "${sourceDir}/build/unit_tests"
                        ]
                    }
                ]
            }
        }
    ]
}
